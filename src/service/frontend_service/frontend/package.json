{
  "name": "open-avatar-chat-webui",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "main": "./dist-electron/out/main/index.js",
  "scripts": {
    "build": "vue-tsc && vite build",
    "dev": "vite",
    "prepare": "husky install",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build",
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts,.vue --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run electron:build && electron-builder --win",
    "build:mac": "pnpm run electron:build && electron-builder --mac",
    "build:linux": "pnpm run electron:build && electron-builder --linux"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@types/dagre": "^0.7.53",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.0",
    "@vue-flow/minimap": "^1.5.4",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.12.2",
    "base64-js": "^1.5.1",
    "buffer": "^6.0.3",
    "click-outside-vue3": "^4.0.1",
    "dagre": "^0.8.5",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.6.2",
    "element-plus": "^2.14.0",
    "eventemitter3": "^5.0.1",
    "gaussian-splat-renderer-for-lam": "^0.0.8",
    "hls.js": "^1.6.13",
    "mrmime": "^2.0.1",
    "nanoid": "^5.1.6",
    "node-fetch": "^3.3.2",
    "p-queue": "^8.1.1",
    "pinia": "^3.0.3",
    "python-struct": "^1.1.3",
    "vue": "^3.5.22",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@rushstack/eslint-patch": "^1.14.0",
    "@types/node": "^22.18.12",
    "@types/python-struct": "^1.0.4",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "dotenv": "^17.2.3",
    "electron": "^38.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.1",
    "eslint": "^9.38.0",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "less": "^4.4.2",
    "lint-staged": "^16.2.5",
    "prettier": "^3.6.2",
    "simple-git-hooks": "^2.13.1",
    "terser": "^5.44.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vite-plugin-mkcert": "^1.17.9",
    "vue": "^3.5.21",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.10.0+sha512.d615db246fe70f25dcfea6d8d73dee782ce23e2245e3c4f6f888249fb568149318637dca73c2c5c8ef2a4ca0d5657fb9567188bfab47f566d1ee6ce987815c39"
}
